# Square credentials — set these in Netlify (Site settings -> Environment variables).
# NEVER commit real values. Copy to .env for local `netlify dev` testing only.

SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=production

# Optional. The single service used behind the scenes for date/time-only
# bookings (the customer never sees it). If unset, the server auto-picks a
# generic "appointment" service. Recommended: your "Book your appointment
# today..." placeholder variation id.
SQUARE_DEFAULT_SERVICE_VARIATION_ID=
